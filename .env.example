# Anthropic — used by aiService.js for all Claude calls
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Google Gemini — reserved for future gemini_process step type
GEMINI_API_KEY=

# Server
PORT=3000
NODE_ENV=development

# Database
DB_PATH=./data/workflows.db

# Webhook HMAC signing secret — use a long random string in production
WEBHOOK_SECRET=change-me-to-a-random-string

# Logging
LOG_LEVEL=info

# AI settings
AI_MODEL=claude-sonnet-4-20250514
AI_MAX_TOKENS=1024

# HTTP fetch settings
FETCH_TIMEOUT_MS=10000
FETCH_RETRY_COUNT=3
